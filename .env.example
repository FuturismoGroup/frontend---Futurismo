# ============================================================
# FUTURISMO FRONTEND - Template de configuracion
# ============================================================
# Copiar a .env y ajustar valores segun sea necesario.
# Las variables de entorno especificas estan en:
#   .env.development  (desarrollo local)
#   .env.production   (produccion)
# ============================================================

VITE_APP_NAME=futurismo
VITE_APP_VERSION=25.07.0001
VITE_ENABLE_MOCK_DATA=false
VITE_API_TIMEOUT=30000
VITE_TOKEN_EXPIRY_HOURS=24
VITE_SESSION_TIMEOUT=1800000
VITE_STORAGE_PREFIX=futurismo_
VITE_DEFAULT_PAGE_SIZE=20
VITE_MAX_PAGE_SIZE=100
